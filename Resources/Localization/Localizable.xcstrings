    "Apple Live transcription needs Speech Recognition permission in addition to microphone access.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Apple Live transcription needs Speech Recognition permission in addition to microphone access."

{
  "sourceLanguage": "en",
  "strings": {
    "Validate": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Validate"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "확인"
          }
        }
      }
    },
    "Choose how you want to start and stop recording. You can change these shortcuts later in Settings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose how you want to start and stop recording. You can change these shortcuts later in Settings."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "녹음을 시작하고 멈추는 방법을 선택하세요. 이 단축키는 나중에 설정에서 바꿀 수 있습니다."
          }
        }
      }
    },
    "Paste Again, Recording Cancel, and other shortcuts remain available in Settings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Paste Again, Recording Cancel, and other shortcuts remain available in Settings."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다시 붙여넣기, 녹음 취소 등 다른 단축키는 설정에서 계속 사용할 수 있습니다."
          }
        }
      }
    },
    "Enable at least one recording shortcut to continue.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable at least one recording shortcut to continue."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "계속하려면 녹음 단축키를 하나 이상 활성화하세요."
          }
        }
      }
    },
    "Hold to Talk": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Hold to Talk"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "길게 눌러 말하기"
          }
        }
      }
    },
    "Tap to Toggle": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to Toggle"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "눌러서 전환"
          }
        }
      }
    },
    "Use either recording shortcut anywhere on your Mac to start your first recording.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Use either recording shortcut anywhere on your Mac to start your first recording."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Mac 어디서든 두 녹음 단축키 중 하나를 사용해 첫 녹음을 시작하세요."
          }
        }
      }
    },
    "On this Mac · Apple Speech · Whisper is downloading and will become active when ready.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "On this Mac · Apple Speech · Whisper is downloading and will become active when ready."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 Mac에서 · Apple Speech · Whisper가 다운로드 중이며 준비되면 활성화됩니다."
          }
        }
      }
    },
    "Whisper will become active when the download finishes.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Whisper will become active when the download finishes."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드가 끝나면 Whisper가 활성화됩니다."
          }
        }
      }
    },
    "Download continues in the background. Select Whisper after installation.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Download continues in the background. Select Whisper after installation."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다운로드가 백그라운드에서 계속됩니다. 설치 후 Whisper를 선택하세요."
          }
        }
      }
    },
    "The download continues in the background while Quill is running.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "The download continues in the background while Quill is running."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Quill이 실행되는 동안 다운로드가 백그라운드에서 계속됩니다."
          }
        }
      }
    },
    "Quit while models are downloading?": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quit while models are downloading?"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "모델을 다운로드하는 중에 종료할까요?"
          }
        }
      }
    },
    "Quill will cancel unfinished model downloads and delete partial files before quitting.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quill will cancel unfinished model downloads and delete partial files before quitting."
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "종료하기 전에 Quill이 완료되지 않은 모델 다운로드를 취소하고 partial 파일을 삭제합니다."
          }
        }
      }
    },
    "Quit and Cancel Downloads": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Quit and Cancel Downloads"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "종료하고 다운로드 취소"
          }
        }
      }
    },
    "Add a custom model ID when it is not listed in the main Model menu.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a custom model ID when it is not listed in the main Model menu."
